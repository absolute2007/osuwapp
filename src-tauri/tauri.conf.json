{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Osuwapp",
  "version": "0.1.1",
  "identifier": "com.dundut.osuwapp",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Osuwapp",
        "width": 1440,
        "height": 920,
        "minWidth": 1120,
        "minHeight": 760,
        "decorations": false,
        "resizable": true,
        "fullscreen": false,
        "shadow": true,
        "backgroundColor": "#111318"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/asdf-overlay/asdf_overlay-x64.dll",
      "resources/asdf-overlay/asdf_overlay-x86.dll"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
